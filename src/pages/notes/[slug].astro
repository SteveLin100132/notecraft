---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagEditor from "@/components/islands/TagEditor.tsx";
import Toc from "@/components/islands/Toc.tsx";
import RegenerateButton from "@/components/islands/RegenerateButton.tsx";
import DeleteNoteButton from "@/components/islands/DeleteNoteButton.tsx";
import FavoriteButton from "@/components/islands/FavoriteButton.tsx";
import ReadingControl from "@/components/islands/ReadingControl.tsx";
import DonePrompt from "@/components/islands/DonePrompt.tsx";
import SeriesNav from "@/components/islands/SeriesNav.tsx";
import AiMarkerCard from "@/components/AiMarkerCard.astro";
import Icon from "@/components/Icon.astro";
import { getAllNotes, parseMarkers, tagStats } from "@/lib/notes";
import { seriesOf } from "@/lib/series";
import { fmtDate } from "@/lib/dates";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((n) => ({ params: { slug: n.slug }, props: { note: n } }));
}

const { note } = Astro.props;
const { Content, headings } = await note.render();
const markers = parseMarkers(note.body);
const genCount = markers.filter((m) => m.status === "generated").length;
const pendingMarkers = markers.filter((m) => m.status !== "generated");
const pendingIds = pendingMarkers.map((m) => m.id);
const isDev = import.meta.env.DEV;
const noteAbsPath = `${process.cwd()}/src/content/notes/${note.id}`;
// vscode:// 需要正斜線路徑；Windows 的 process.cwd() 會帶反斜線，且磁碟機代號前要補一個斜線
const vscodeHref = `vscode://file/${noteAbsPath.replace(/\\/g, "/").replace(/^\/+/, "")}`;

const allNotes = await getAllNotes();
const stats = tagStats(allNotes).map((t) => ({ name: t.name, count: t.count }));
const series = seriesOf(allNotes, note.slug);
const seriesNavData = series
  ? {
      id: series.series.id,
      title: series.series.title,
      eyebrow: series.series.eyebrow,
      accent: series.series.accent,
      icon: series.series.icon,
      chapters: series.chapters.map((c) => ({ slug: c.slug, title: c.title })),
      currentIndex: series.index,
    }
  : null;

const toc = headings.filter((h) => h.depth === 2).map((h) => ({ id: h.slug, label: h.text }));
---
<BaseLayout title={note.data.title} current="notes" description={note.data.description}>
  <a
    href="/notes"
    style="display:inline-flex;align-items:center;gap:5px;color:var(--text-muted);font-size:13.5px;font-weight:600;text-decoration:none;margin-bottom:18px;"
  >
    <Icon name="chevronLeft" size={16} /> 返回筆記列表
  </a>

  <div class={`nc-note-grid ${toc.length ? "has-toc" : ""}`}>
    <article class="nc-note-article" style="min-width:0;max-width:760px;">
      <div style="margin-bottom:14px;">
        <TagEditor
          client:load
          slug={note.slug}
          initialTags={note.data.tags}
          editable={isDev}
          suggestions={stats}
        />
      </div>

      <h1 class="nc-note-title" style="color:var(--text-strong);line-height:1.2;margin:0 0 14px;font-weight:900;">
        {note.data.title}
      </h1>
      <p style="font-size:var(--text-lg);color:var(--text-muted);line-height:1.7;margin:0 0 18px;">
        {note.data.description}
      </p>

      <div
        style="display:flex;flex-wrap:wrap;align-items:center;gap:14px;padding-bottom:18px;margin-bottom:8px;border-bottom:1px solid var(--neutral-200);font-size:13px;color:var(--text-muted);"
      >
        <span style="display:inline-flex;align-items:center;gap:5px;">
          <Icon name="clock" size={15} /> 更新於 {fmtDate(note.data.updatedAt)}
        </span>
        {markers.length > 0 && (
          <span style="display:inline-flex;align-items:center;gap:5px;">
            <Icon name="sparkle" size={15} style="color:var(--orange-500);" />
            {genCount}/{markers.length} 視覺化已生成
          </span>
        )}
        <ReadingControl client:idle slug={note.slug} />
        <span class="nc-note-actions" style="margin-left:auto;display:inline-flex;gap:8px;flex-wrap:wrap;">
          <FavoriteButton client:idle slug={note.slug} />
          {isDev && (
            <a
              href={vscodeHref}
              style="display:inline-flex;align-items:center;gap:6px;height:34px;padding:0 14px;border-radius:999px;background:var(--action-secondary);color:#fff;font-size:13px;font-weight:700;text-decoration:none;white-space:nowrap;"
            >
              <Icon name="edit" size={15} /> 以 VS Code 編輯
            </a>
          )}
          {isDev && pendingIds.length > 0 && (
            <RegenerateButton client:idle slug={note.slug} pendingIds={pendingIds} />
          )}
          {isDev && (
            <DeleteNoteButton
              client:idle
              slug={note.slug}
              title={note.data.title}
              componentIds={markers.map((m) => m.id)}
            />
          )}
        </span>
      </div>

      {/* 已生成的標記，其提示詞已由下方 GeneratedFrame 卡片（含複製按鈕）呈現，
          這裡只保留尚未生成（pending / failed / locked）的標記提示，避免重複。 */}
      {pendingMarkers.length > 0 && (
        <div style="margin:18px 0 6px;">
          {pendingMarkers.map((m) => (
            <AiMarkerCard id={m.id} type={m.type} status={m.status} prompt={m.prompt} />
          ))}
        </div>
      )}

      <div class="nc-prose" data-pagefind-body>
        <Content />
      </div>

      <DonePrompt client:visible slug={note.slug} />

      <div
        style="margin-top:44px;padding-top:22px;border-top:1px solid var(--neutral-200);display:flex;justify-content:space-between;color:var(--text-muted);font-size:13px;"
      >
        <span>建立於 {fmtDate(note.data.createdAt)}</span>
        <span style="font-family:var(--font-mono);">src/content/notes/{note.id}</span>
      </div>

      {seriesNavData && <SeriesNav client:visible series={seriesNavData} />}
    </article>

    {toc.length > 0 && (
      <div class="nc-toc-col">
        <Toc client:visible items={toc} />
      </div>
    )}
  </div>
</BaseLayout>

<style is:global>
  .nc-note-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }
  .nc-note-title {
    font-size: var(--text-4xl);
  }
  @media (max-width: 1024px) {
    .nc-note-title {
      font-size: var(--text-3xl);
    }
  }
  @media (min-width: 1025px) {
    .nc-note-grid.has-toc {
      grid-template-columns: 1fr 220px;
    }
    /* 讓目錄欄拉伸到整欄高度，sticky 才有可黏附的範圍 */
    .nc-toc-col {
      align-self: stretch;
    }
  }
  /* 桌面：右側黏性目錄 */
  .nc-toc {
    position: sticky;
    top: 8px;
  }
  .nc-toc-head {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
    padding: 0;
    margin-bottom: 12px;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    cursor: default;
  }
  /* 桌面不需要折疊箭頭 */
  .nc-toc-chevron {
    display: none;
  }

  /* 平板 / 手機：單欄 + 目錄改為可折疊面板置於內文上方 */
  @media (max-width: 1024px) {
    .nc-note-grid {
      gap: 0;
    }
    .nc-toc-col {
      order: -1;
      margin-bottom: 18px;
    }
    .nc-toc {
      position: static;
      border: 1px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      background: #fff;
      padding: 12px 16px;
      box-shadow: var(--shadow-xs);
    }
    .nc-toc-head {
      justify-content: space-between;
      margin-bottom: 0;
      cursor: pointer;
    }
    .nc-toc-head[aria-expanded="true"] {
      margin-bottom: 12px;
    }
    .nc-toc-chevron {
      display: inline-flex;
      transition: transform 200ms ease-out;
    }
    /* 頁首動作鈕：自成一行、靠左、可換行，不再被壓窄 */
    .nc-note-actions {
      margin-left: 0 !important;
      flex-basis: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nc-toc-chevron {
      transition: none;
    }
  }
</style>

<script>
  // Content tabs（PRD §7.1 / task-15）漸進增強：框架無關 vanilla JS，不引入 React island。
  // 無此 script 時 CSS 會展開所有面板（不遺失內容）；載入後才接管切換。
  function initTabs(root: HTMLElement) {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[role="tabpanel"]'));
    if (!tabs.length) return;
    root.setAttribute("data-enhanced", "");

    const select = (i: number) => {
      tabs.forEach((tab, j) => {
        const selected = j === i;
        tab.setAttribute("aria-selected", selected ? "true" : "false");
        tab.tabIndex = selected ? 0 : -1;
        if (panels[j]) panels[j].hidden = !selected;
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        select(i);
        tab.focus();
      });
      tab.addEventListener("keydown", (e: KeyboardEvent) => {
        let next: number | null = null;
        if (e.key === "ArrowRight") next = (i + 1) % tabs.length;
        else if (e.key === "ArrowLeft") next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") next = 0;
        else if (e.key === "End") next = tabs.length - 1;
        else return;
        e.preventDefault();
        select(next);
        tabs[next].focus();
      });
    });

    const initial = tabs.findIndex((t) => t.getAttribute("aria-selected") === "true");
    select(initial < 0 ? 0 : initial);
  }

  document.querySelectorAll<HTMLElement>("[data-nc-tabs]").forEach(initTabs);

  // Tooltips（PRD §7.1 / task-16）定位：氣泡採 position:fixed，於 hover / focus 時以 JS
  // 夾在內容捲動區內，避免被 table/tabs 的 overflow 裁切、超出視窗或被 sidebar 遮蔽。
  function positionTip(tip: HTMLElement) {
    const bubble = tip.querySelector<HTMLElement>(".nc-tip__bubble");
    if (!bubble) return;
    bubble.style.left = "0px";
    bubble.style.top = "0px";
    const tr = tip.getBoundingClientRect();
    const bw = bubble.offsetWidth;
    const bh = bubble.offsetHeight;
    const scroll = document.getElementById("nc-scroll");
    const sr = scroll
      ? scroll.getBoundingClientRect()
      : ({ left: 8, right: window.innerWidth - 8, top: 8 } as DOMRect);
    const minX = Math.max(8, sr.left + 8);
    const maxX = Math.min(window.innerWidth - 8, sr.right - 8);
    let left = tr.left + tr.width / 2 - bw / 2;
    left = Math.max(minX, Math.min(left, maxX - bw));
    let top = tr.top - bh - 9;
    const below = top < sr.top + 8;
    if (below) top = tr.bottom + 9;
    bubble.style.left = `${Math.round(left)}px`;
    bubble.style.top = `${Math.round(top)}px`;
    bubble.style.setProperty(
      "--nc-tip-arrow",
      `${Math.round(tr.left + tr.width / 2 - left)}px`,
    );
    bubble.classList.toggle("nc-tip__bubble--below", below);
  }

  document.querySelectorAll<HTMLElement>(".nc-tip").forEach((tip) => {
    tip.addEventListener("mouseenter", () => positionTip(tip));
    tip.addEventListener("focusin", () => positionTip(tip));
  });
</script>
